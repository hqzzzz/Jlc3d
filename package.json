{
  "name": "jlc3d-downloader",
  "version": "1.2.0",
  "description": "嘉立创 3D 模型下载器 - Electron 版本",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "keywords": [
    "electron",
    "jlc",
    "3d-model",
    "downloader"
  ],
  "author": "Jupiter",
  "license": "MIT",
  "build": {
    "appId": "com.jupiter.jlc3d",
    "productName": "嘉立创 3D 模型下载器",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": null
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.2"
  }
}
